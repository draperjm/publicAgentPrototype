# =============================================================================
# Agent 07 — Azure Container Apps deployment secrets
# Copy this file to .env.production and fill in real values.
# .env.production is git-ignored; never commit real API keys.
# =============================================================================

# LLM API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Optional: override default model names
# LLM_MODEL=gpt-4o
# TAGGING_MODEL=gpt-4o-mini
# VISION_MODEL=gemini-2.0-flash
# ASSET_EXTRACTION_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-2.0-flash
# VALIDATOR_MODEL=gpt-4o
# ANALYTICS_MODEL=gpt-4o
