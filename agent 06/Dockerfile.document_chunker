FROM python:3.9-slim

WORKDIR /app

# poppler-utils is required by pdf2image to render PDF pages
RUN apt-get update && apt-get install -y --no-install-recommends \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

COPY requirements_document_chunker.txt .
RUN pip install --no-cache-dir -r requirements_document_chunker.txt

COPY document_chunker.py .

EXPOSE 8091

CMD ["uvicorn", "document_chunker:app", "--host", "0.0.0.0", "--port", "8091"]
