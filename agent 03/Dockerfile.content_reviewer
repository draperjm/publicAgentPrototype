# Dockerfile.content_reviewer
FROM python:3.9-slim

WORKDIR /app

# Install dependencies for PDF (poppler) and general build tools
RUN apt-get update && apt-get install -y build-essential libpoppler-cpp-dev && rm -rf /var/lib/apt/lists/*

COPY requirements_reviewer.txt .
RUN pip install --no-cache-dir -r requirements_reviewer.txt

COPY content_reviewer.py .

EXPOSE 8085

CMD ["uvicorn", "content_reviewer:app", "--host", "0.0.0.0", "--port", "8085"]