FROM python:3.9-slim

WORKDIR /app

# System dependencies for pdfplumber
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpoppler-cpp-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements_document_extractor.txt .
RUN pip install --no-cache-dir -r requirements_document_extractor.txt

COPY document_extractor.py .

EXPOSE 8090

CMD ["uvicorn", "document_extractor:app", "--host", "0.0.0.0", "--port", "8090"]
