FROM python:3.9-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code and all config it needs at runtime
COPY orchestrator.py .
COPY tasks.json .
COPY registry.json .
COPY process/ ./process/
COPY common/ ./common/

EXPOSE 8001

CMD ["uvicorn", "orchestrator:app", "--host", "0.0.0.0", "--port", "8001", "--timeout-keep-alive", "300"]
